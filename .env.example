# =============================================================================
# GreenOps Auto-Remediador — Variáveis de Ambiente
# =============================================================================
# Copie este arquivo para .env e preencha os valores reais.
# NUNCA commite o arquivo .env no repositório.
# =============================================================================

# -----------------------------------------------------------------------------
# AWS — Configuração da conta e região
# -----------------------------------------------------------------------------

# Região AWS onde os recursos serão gerenciados
AWS_REGION=us-east-1

# Profile AWS CLI a ser usado localmente (deixe em branco para usar o default)
# AWS_PROFILE=greenops-dev

# -----------------------------------------------------------------------------
# GreenOps — Configuração do ambiente
# -----------------------------------------------------------------------------

# Ambiente de execução: dev | staging | prod
GREENOPS_ENVIRONMENT=dev

# Modo dry-run: true = apenas simula ações, não aplica nada
# Recomendado manter true até validar o comportamento no seu ambiente
GREENOPS_DRY_RUN=true

# -----------------------------------------------------------------------------
# Notificações e aprovações
# -----------------------------------------------------------------------------

# Email que receberá notificações de findings e remediações aplicadas
APPROVER_EMAIL=ops-team@example.com

# Webhook do Slack para alertas em tempo real (opcional)
# Formato: https://hooks.slack.com/services/T.../B.../...
SLACK_WEBHOOK_URL=

# -----------------------------------------------------------------------------
# Agendamentos (formato EventBridge / cron)
# -----------------------------------------------------------------------------

# Frequência de execução do discovery de recursos desperdiçados
# Exemplos: "rate(6 hours)" | "rate(1 day)" | "cron(0 */6 * * ? *)"
DISCOVERY_SCHEDULE=rate(6 hours)

# Frequência de geração de relatórios de sustentabilidade e custo
# Padrão: todo dia às 08:00 UTC
REPORTING_SCHEDULE=cron(0 8 * * ? *)

# -----------------------------------------------------------------------------
# Limites de segurança — controle de blast radius
# -----------------------------------------------------------------------------

# Número máximo de ações de remediação por hora (qualquer tipo)
MAX_ACTIONS_PER_HOUR=10

# Número máximo de ações destrutivas por dia
# Ações destrutivas: stop de instâncias, delete de volumes, release de EIPs
MAX_DESTRUCTIVE_ACTIONS_PER_DAY=5

# -----------------------------------------------------------------------------
# Tags de controle — quais recursos o GreenOps pode gerenciar
# -----------------------------------------------------------------------------

# Tags obrigatórias que um recurso deve ter para ser elegível à remediação
# Formato: JSON com pares chave=valor separados por vírgula
# Exemplo: {"GreenOpsManaged": "true", "Team": "platform"}
REQUIRED_TAGS={"GreenOpsManaged": "true"}

# Tag que protege um recurso de qualquer ação automática
PROTECTION_TAG=GreenOpsProtected

# Valores da tag de proteção que bloqueiam remediação
# Formato: lista separada por vírgula
PROTECTION_VALUES=true,yes,1
